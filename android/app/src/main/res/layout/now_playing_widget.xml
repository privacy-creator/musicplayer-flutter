<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Album art / placeholder -->
    <ImageView
        android:id="@+id/widget_art"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@drawable/ic_widget_music"
        android:scaleType="centerCrop"
        android:background="#282828"
        android:contentDescription="Album art"/>

    <!-- Title + artist -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not playing"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#B3B3B3"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- Shuffle -->
    <ImageButton
        android:id="@+id/widget_shuffle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_widget_shuffle"
        android:background="@android:color/transparent"
        android:contentDescription="Shuffle"
        android:scaleType="centerInside"/>

    <!-- Prev -->
    <ImageButton
        android:id="@+id/widget_prev"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_widget_prev"
        android:background="@android:color/transparent"
        android:contentDescription="Previous"
        android:scaleType="centerInside"/>

    <!-- Play / Pause -->
    <ImageButton
        android:id="@+id/widget_play_pause"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_widget_play"
        android:background="@android:color/transparent"
        android:contentDescription="Play or pause"
        android:scaleType="centerInside"/>

    <!-- Next -->
    <ImageButton
        android:id="@+id/widget_next"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_widget_next"
        android:background="@android:color/transparent"
        android:contentDescription="Next"
        android:scaleType="centerInside"/>

</LinearLayout>
